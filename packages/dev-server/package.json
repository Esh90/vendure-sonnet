{
    "name": "dev-server",
    "version": "3.6.3",
    "main": "index.js",
    "license": "GPL-3.0-or-later",
    "private": true,
    "scripts": {
        "populate": "node -r ts-node/register -r dotenv/config populate-dev-server.ts",
        "dev:server": "vendure dev server --server-entry ./index.ts",
        "dev:server:instrumented": "IS_INSTRUMENTED=true node -r ts-node/register -r dotenv/config -r tsconfig-paths/register -r ./instrumentation.ts index.ts",
        "dev:worker": "vendure dev worker --worker-entry ./index-worker.ts",
        "dev:worker:instrumented": "IS_INSTRUMENTED=true node -r ts-node/register -r dotenv/config -r tsconfig-paths/register -r ./instrumentation.ts index-worker.ts",
        "dev": "vendure dev all --server-entry ./index.ts --worker-entry ./index-worker.ts",
        "dev:instrumented": "concurrently npm:dev:server:instrumented npm:dev:worker:instrumented",
        "dashboard:dev": "vendure dev dashboard",
        "build": "vendure build all",
        "build:server": "vendure build server",
        "build:worker": "vendure build worker",
        "build:dashboard": "vendure build dashboard",
        "start": "vendure start all",
        "start:server": "vendure start server",
        "start:worker": "vendure start worker",
        "load-test:1k": "node -r ts-node/register load-testing/run-load-test.ts 1000",
        "load-test:10k": "node -r ts-node/register load-testing/run-load-test.ts 10000",
        "load-test:100k": "node -r ts-node/register load-testing/run-load-test.ts 100000"
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.0",
        "@vendure/admin-ui-plugin": "3.6.3",
        "@vendure/asset-server-plugin": "3.6.3",
        "@vendure/common": "3.6.3",
        "@vendure/core": "3.6.3",
        "@vendure/email-plugin": "3.6.3",
        "typescript": "5.8.2"
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260515.1",
        "@vendure/cli": "3.6.3",
        "@vendure/testing": "3.6.3",
        "@vendure/ui-devkit": "3.6.3",
        "commander": "^12.0.0",
        "concurrently": "^9.2.0",
        "csv-stringify": "^6.4.6",
        "dayjs": "^1.11.10",
        "jsdom": "^26.0.0",
        "progress": "^2.0.3",
        "tsconfig-paths": "^4.2.0"
    }
}
